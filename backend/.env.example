# Copy this file to .env and fill in the values

# Neon (recomendado): desative connection pooling e copie a URL direto do dashboard
# DATABASE_URL=postgresql+asyncpg://user:senha@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Postgres local (alternativa)
# DATABASE_URL=postgresql+asyncpg://postgres:senha@localhost:5432/ultimatetracker

DATABASE_URL=postgresql+asyncpg://user:senha@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
SESSION_SECRET=change_this_to_a_random_secret_string
SITE_URL=http://localhost:3000
