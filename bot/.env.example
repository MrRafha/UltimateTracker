# Copy this file to .env and fill in the values
DISCORD_TOKEN=your_bot_token_here
API_BASE_URL=http://localhost:8000
SITE_URL=http://localhost:3000

# Deve ser igual ao BOT_SECRET no backend/.env
BOT_SECRET=change_this_to_a_random_secret_string

# Map of guild_id -> api_key  (filled automatically after /setup or manual registration)
# GUILD_API_KEYS={"123456789": "your-api-key-here"}
GUILD_API_KEYS={}

# Map of guild_id -> language code  (set automatically via /setup language selection)
# Supported: en, pt-BR, es, zh
# GUILD_LANGUAGES={"123456789": "pt-BR"}
GUILD_LANGUAGES={}
